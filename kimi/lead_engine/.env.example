# ==============================================
# Lead Extraction Engine -- Environment Variables
# ==============================================

# Engine Database (NEW -- separate from RMD system)
ENGINE_DB_HOST=localhost
ENGINE_DB_PORT=5432
ENGINE_DB_NAME=lead_engine_db
ENGINE_DB_USER=crwm_user
ENGINE_DB_PASSWORD=crwm_password

# RMD Source Database (your existing crwm_db -- READ ONLY)
RMD_DB_HOST=localhost
RMD_DB_PORT=5432
RMD_DB_NAME=crwm_db
RMD_DB_USER=crwm_user
RMD_DB_PASSWORD=crwm_password

# Apollo.io API (single enrichment provider)
APOLLO_API_KEY=your_apollo_api_key_here

# Rate Limits (requests per minute)
APOLLO_RATE_LIMIT=40
APOLLO_MONTHLY_CREDIT_LIMIT=8000
APOLLO_DAILY_CREDIT_LIMIT=200
APOLLO_MAX_CREDITS_PER_RUN=50

# Enrichment Settings
ENRICH_BATCH_SIZE=100

# Export Directory
EXPORT_DIR=data/exports

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/extraction.log
